# Copy this file to .env and fill in real values. Never commit .env.

ANTHROPIC_API_KEY=sk-ant-...
BRAVE_SEARCH_API_KEY=...

# Comma-separated list of allowed extension/site origins for CORS.
# Chrome extensions originate as chrome-extension://<extension-id>
ALLOWED_ORIGINS=chrome-extension://your-extension-id-here

PORT=8787


# Base URL used to build shareable links. Set to your deployed domain in production.
# Defaults to http://localhost:PORT if not set.
PUBLIC_URL=https://your-deployed-domain.com
